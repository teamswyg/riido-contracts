  "policies": [
    {
      "policy_id": "ai_agent_rbac.v1",
      "kind": "rbac",
      "description": "Admin can read and mutate all workspace agents; agent owner is admin-equivalent only for owned agents; non-admin users read owned agents plus other users' public agents.",
      "rules": [
        "admin: read public and private agents, update all, delete all",
        "owner: read owned agents, update owned agents, delete owned agents",
        "user: read owned agents and other users' public agents only"
      ]
    },
    {
      "policy_id": "agent_mutation_safety.v1",
      "kind": "lifecycle",
      "description": "Deleting an agent force-unassigns queued tasks and force-stops running tasks; editing display/configuration/profile fields is allowed only when the agent has no assigned tasks, and editability must be visible to clients before mutation.",
      "rules": [
        "delete: unassign queued tasks and force-stop running tasks before confirming deletion",
        "edit: allowed only when assigned_task_count is zero",
        "editability: emitted through query and SSE before a client enables editing"
      ]
    },
    {
      "policy_id": "runtime_liveness.v1",
      "kind": "liveness",
      "description": "Daemon-owned runtime detection controls online/offline policy for agent assignments.",
      "rules": [
        "daemon: scan runtimes immediately after start",
        "daemon: scan runtimes every 30 seconds after start",
        "daemon: queue detection results and let the actor model edit state",
        "runtime_deleted_with_assigned_agent: mark runtime offline",
        "runtime_deleted_without_assigned_agent: treat runtime as absent",
        "runtime_reinstalled_same_device: mark runtime online according to online/offline policy only",
        "runtime_detection_error: expose offline to clients"
      ]
    },
    {
      "policy_id": "api_codegen_safety.v1",
      "kind": "projection",
      "description": "Control-plane API enums and union values are owned in DSL and preserved in IR before OpenAPI generation so Orval/client codegen gets safe discriminated shapes.",
      "rules": [
        "enum: define as top-level DSL enum, not ad hoc string documentation",
        "sum_type: define discriminator and variants in DSL and IR",
        "openapi: generated projection only",
        "client: consumes OpenAPI projection with Orval or a compatible generator"
      ]
    },
    {
      "policy_id": "task_thread_progress_batching.v1",
      "kind": "telemetry",
      "description": "Daemon reports parsed runtime progress to the control plane as bounded task-thread batches instead of streaming provider tokens directly.",
      "rules": [
        "daemon: parse only explicit runtime progress markers such as \u003criido_log\u003e...\u003cend\u003e",
        "daemon: batch parsed progress lines before SaaS ingest; default cadence is 10 seconds",
        "daemon: flush pending progress before terminal assignment events",
        "server: fan out accepted progress batches through the client event stream as typed task-thread progress events",
        "client: render task-thread progress from typed event payloads and never parse provider raw output"
      ]
    },
    {
      "policy_id": "agent_profile_configuration.v1",
      "kind": "profile",
      "description": "Agent profile presentation fields are saved with the agent configuration and projected to client bootstrap, task assignment, and update responses.",
      "rules": [
        "profile_thumbnail_url: optional HTTPS image URL string; binary upload is outside this contract",
        "description: optional client-authored one-line summary with a maximum of 160 characters; empty string is allowed; client UI owns truncation and wrapping",
        "instruction: optional client-authored text with a maximum of 1000 characters; empty string is allowed",
        "mutation: profile fields follow agent_mutation_safety.v1 and ai_agent_rbac.v1"
      ]
    }
  ],
