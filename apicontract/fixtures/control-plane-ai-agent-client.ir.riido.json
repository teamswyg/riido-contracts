    {
      "scenario_id": "getAIAgentClientBootstrap.figma-client-bootstrap",
      "operation_id": "getAIAgentClientBootstrap",
      "name": "figma client bootstrap",
      "given": "a web or desktop webview client opens the v1.22 AI Agent surface",
      "when": "the client requests bootstrap data",
      "then": "the response contains visible agents and owned device runtimes required by the Figma onboarding and agent setting screens"
    },
    {
      "scenario_id": "listAIAgentDeviceRuntimes.missing-runtime-with-assigned-agent-is-offline",
      "operation_id": "listAIAgentDeviceRuntimes",
      "name": "missing runtime with assigned agent is offline",
      "given": "a runtime was deleted on a device and at least one assigned agent references it",
      "when": "daemon scan reports the runtime missing",
      "then": "the client sees that runtime as offline instead of absent"
    },
    {
      "scenario_id": "listAIAgentDeviceRuntimes.missing-runtime-without-assigned-agent-is-absent",
      "operation_id": "listAIAgentDeviceRuntimes",
      "name": "missing runtime without assigned agent is absent",
      "given": "a runtime was deleted on a device and no assigned agent references it",
      "when": "daemon scan reports the runtime missing",
      "then": "the client list omits the runtime as if it never existed"
    },
    {
      "scenario_id": "listAIAgentTaskAssignableAgents.participant-dropdown-visible-agents",
